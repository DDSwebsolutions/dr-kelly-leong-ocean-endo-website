---
import { Image } from 'astro:assets';
import { site, footerServiceLinks, footerQuickLinks, legalNav } from '@data/site';
import { cities } from '@data/cities';
import logoStacked from '@assets/images/brand/logo-stacked.png';

const year = new Date().getFullYear();
---

<footer class="mt-24 border-t border-line bg-surface-subtle text-ink-soft">
  <!-- Emergency strip -->
  <div class="bg-ink text-white">
    <div class="mx-auto max-w-wide px-6 py-5 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-3">
      <p class="text-primary-100">
        <span class="font-semibold text-white">Dental emergency?</span>
        Call us as early as you can and we will do our best to see you the same day.
      </p>
      <a href={site.phone.href} class="inline-flex items-center gap-2 rounded-full bg-white px-5 py-2.5 font-semibold text-ink no-underline hover:-translate-y-0.5 transition-transform">
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" aria-hidden="true"><path d="M5 4h3l2 5-2.5 1.5a11 11 0 0 0 5 5L14 12l5 2v3a2 2 0 0 1-2 2A15 15 0 0 1 3 6a2 2 0 0 1 2-2Z" stroke-linejoin="round"/></svg>
        {site.phone.display}
      </a>
    </div>
  </div>

  <div class="mx-auto max-w-wide px-6 py-14">
    <div class="grid gap-10 lg:grid-cols-12">
      <!-- Brand -->
      <div class="lg:col-span-4">
        <Image src={logoStacked} alt="Ocean Endodontics, The Dental Group of Dr. Kelly Kimiko Leong" width={220} densities={[1, 2, 3]} quality={92} class="h-auto w-48" />
        <p class="mt-5 max-w-sm text-[0.95rem]">
          {site.legalName}. Board-certified endodontist {site.doctor.name} provides gentle root canal therapy, retreatment, microsurgery, and same-day emergency care to save natural teeth in San Francisco.
        </p>
        <div class="mt-5 flex items-center gap-3">
          <a href={site.social.instagram} target="_blank" rel="noopener noreferrer" class="inline-flex w-10 h-10 items-center justify-center rounded-full ring-1 ring-line-strong text-ink hover:bg-white" aria-label="Instagram">
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/></svg>
          </a>
          <a href={site.social.google} target="_blank" rel="noopener noreferrer" class="inline-flex h-10 items-center justify-center rounded-full ring-1 ring-line-strong px-4 text-sm font-semibold text-ink hover:bg-white no-underline">Google</a>
          <a href={site.social.yelp} target="_blank" rel="noopener noreferrer" class="inline-flex h-10 items-center justify-center rounded-full ring-1 ring-line-strong px-4 text-sm font-semibold text-ink hover:bg-white no-underline">Yelp</a>
        </div>
      </div>

      <!-- Services -->
      <nav class="lg:col-span-2" aria-label="Services">
        <h2 class="text-sm font-semibold uppercase tracking-wide text-ink">Services</h2>
        <ul class="mt-4 space-y-2.5 text-[0.95rem]">
          {footerServiceLinks.map((l) => (
            <li><a href={l.href} class="text-ink-soft hover:text-accent-strong no-underline">{l.label}</a></li>
          ))}
          <li><a href="/services" class="font-semibold text-accent-strong no-underline">All services →</a></li>
        </ul>
      </nav>

      <!-- Quick links -->
      <nav class="lg:col-span-2" aria-label="Quick links">
        <h2 class="text-sm font-semibold uppercase tracking-wide text-ink">Explore</h2>
        <ul class="mt-4 space-y-2.5 text-[0.95rem]">
          {footerQuickLinks.map((l) => (
            <li><a href={l.href} class="text-ink-soft hover:text-accent-strong no-underline">{l.label}</a></li>
          ))}
          <li><a href={site.portals.patient} target="_blank" rel="noopener noreferrer" class="text-ink-soft hover:text-accent-strong no-underline">Patient Portal (Login)</a></li>
          <li><a href="/for-doctors" class="text-ink-soft hover:text-accent-strong no-underline">For Referring Doctors</a></li>
        </ul>
      </nav>

      <!-- Contact + hours -->
      <div class="lg:col-span-4">
        <h2 class="text-sm font-semibold uppercase tracking-wide text-ink">Visit us</h2>
        <address class="mt-4 not-italic space-y-2.5 text-[0.95rem]">
          <a href={site.directionsUrl} target="_blank" rel="noopener noreferrer" class="flex items-start gap-2.5 text-ink-soft hover:text-accent-strong no-underline">
            <svg class="w-5 h-5 mt-0.5 shrink-0 text-accent-strong" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" aria-hidden="true"><path d="M12 21s-7-5.7-7-11a7 7 0 1 1 14 0c0 5.3-7 11-7 11Z" stroke-linejoin="round"/><circle cx="12" cy="10" r="2.5"/></svg>
            <span>{site.address.streetLine1}, {site.address.streetLine2}<br />{site.address.city}, {site.address.state} {site.address.zip}</span>
          </a>
          <a href={site.phone.href} class="flex items-center gap-2.5 text-ink-soft hover:text-accent-strong no-underline">
            <svg class="w-5 h-5 text-accent-strong" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" aria-hidden="true"><path d="M5 4h3l2 5-2.5 1.5a11 11 0 0 0 5 5L14 12l5 2v3a2 2 0 0 1-2 2A15 15 0 0 1 3 6a2 2 0 0 1 2-2Z" stroke-linejoin="round"/></svg>
            {site.phone.display}
          </a>
          <a href={site.email.href} class="flex items-center gap-2.5 text-ink-soft hover:text-accent-strong no-underline">
            <svg class="w-5 h-5 text-accent-strong" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" aria-hidden="true"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="m4 7 8 6 8-6"/></svg>
            {site.email.display}
          </a>
          <p class="flex items-center gap-2.5 text-ink-muted"><span class="w-5 text-center">FAX</span>{site.fax.display}</p>
        </address>

        <h3 class="mt-6 text-sm font-semibold uppercase tracking-wide text-ink">Hours</h3>
        <ul class="mt-3 text-[0.9rem] space-y-1">
          {site.hours.map((h) => (
            <li class="flex justify-between max-w-[16rem]">
              <span>{h.day}</span>
              <span class={h.closed ? 'text-ink-muted' : 'font-medium text-ink'}>{h.closed ? 'Closed' : '8:30 AM – 5:00 PM'}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Areas we serve -->
    <nav aria-label="Areas we serve" class="mt-12 pt-8 border-t border-line">
      <h2 class="text-sm font-semibold uppercase tracking-wide text-ink">Areas we serve</h2>
      <ul class="mt-3 flex flex-wrap gap-x-5 gap-y-2 text-[0.95rem]">
        {cities.map((c) => (
          <li><a href={`/areas-we-serve/${c.slug}`} class="text-ink-soft hover:text-accent-strong no-underline">{c.name}</a></li>
        ))}
      </ul>
    </nav>

    <!-- Disclaimers -->
    <div class="mt-10 pt-8 border-t border-line space-y-4 text-[0.8rem] leading-relaxed text-ink-muted">
      <p><strong class="text-ink-soft">Medical disclaimer.</strong> {site.disclaimers.medicalShort} Viewing this site does not create a doctor–patient relationship. {site.disclaimers.specialty}</p>
      <p><strong class="text-urgent">In an emergency.</strong> {site.disclaimers.emergency}</p>
      <p><strong class="text-ink-soft">Text messaging.</strong> {site.disclaimers.smsConsent}</p>
    </div>
  </div>

  <!-- Legal bar -->
  <div class="border-t border-line bg-surface-muted">
    <div class="mx-auto max-w-wide px-6 py-5 flex flex-col md:flex-row items-center justify-between gap-3 text-[0.85rem]">
      <p class="text-ink-muted text-center md:text-left">© {year} {site.name} · {site.legalName}. All rights reserved.</p>
      <nav aria-label="Legal">
        <ul class="flex flex-wrap items-center justify-center gap-x-4 gap-y-1">
          {legalNav.map((l) => (
            <li><a href={l.href} class="text-ink-muted hover:text-accent-strong no-underline">{l.label}</a></li>
          ))}
        </ul>
      </nav>
    </div>
  </div>
</footer>
