---
import { Image } from 'astro:assets';
import { site, primaryNav } from '@data/site';
import logo from '@assets/images/brand/logo-horizontal.png';
import Button from '@components/ui/Button.astro';
import NavIcon from '@components/ui/NavIcon.astro';

const path = Astro.url.pathname.replace(/\/+$/, '') || '/';
const isActive = (href: string) => (href === '/' ? path === '/' : path === href || path.startsWith(href + '/'));

// Desktop nav drops only Home (the logo is Home). Mobile menu keeps the full list.
const desktopNav = primaryNav.filter((i) => i.href !== '/');

// Featured-card tone -> classes (surface + arrow color handled below).
const featuredTone: Record<string, string> = {
  navy: 'bg-ink text-white',
  accent: 'bg-gradient-to-br from-accent to-[#0056b3] text-white',
  urgent: 'bg-gradient-to-br from-urgent to-[#9a330b] text-white',
  default: 'bg-surface-subtle text-ink',
};
---

<!-- Sticky wrapper: the utility bar parks just above the viewport on lg+
     (-top-10 = its exact height), so only the main bar stays pinned. -->
<header class="sticky top-0 lg:-top-10 z-50" data-site-header>
  <!-- Utility bar (scrolls away; only the main bar sticks) -->
  <div class="hidden lg:block bg-ink text-primary-100 text-sm">
    <div class="mx-auto max-w-wide px-6 flex items-center justify-between h-10">
      <div class="flex items-center gap-5">
        <a href={site.directionsUrl} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1.5 text-primary-100 hover:text-white no-underline">
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" aria-hidden="true"><path d="M12 21s-7-5.7-7-11a7 7 0 1 1 14 0c0 5.3-7 11-7 11Z" stroke-linejoin="round"/><circle cx="12" cy="10" r="2.5"/></svg>
          {site.address.full}
        </a>
        <span class="text-primary-300/60" aria-hidden="true">|</span>
        <span class="text-primary-100/90">{site.hoursSummary}</span>
      </div>
      <div class="flex items-center gap-4">
        <a href={site.phone.href} class="inline-flex items-center gap-1.5 font-semibold text-white hover:text-primary-100 no-underline">
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" aria-hidden="true"><path d="M5 4h3l2 5-2.5 1.5a11 11 0 0 0 5 5L14 12l5 2v3a2 2 0 0 1-2 2A15 15 0 0 1 3 6a2 2 0 0 1 2-2Z" stroke-linejoin="round"/></svg>
          {site.phone.display}
        </a>
        <span class="text-primary-300/60" aria-hidden="true">|</span>
        <a href={site.portals.patient} target="_blank" rel="noopener noreferrer" class="text-primary-100 hover:text-white no-underline">Patient Portal</a>
        <span class="text-primary-300/60" aria-hidden="true">|</span>
        <div class="flex items-center gap-3">
          <a href={site.social.instagram} target="_blank" rel="noopener noreferrer" class="text-primary-100 hover:text-white" aria-label="Ocean Endodontics on Instagram">
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/></svg>
          </a>
          <a href={site.social.yelp} target="_blank" rel="noopener noreferrer" class="text-primary-100 hover:text-white no-underline text-xs font-semibold">Yelp</a>
          <a href={site.social.google} target="_blank" rel="noopener noreferrer" class="text-primary-100 hover:text-white no-underline text-xs font-semibold">Google</a>
        </div>
      </div>
    </div>
  </div>

  <!-- Main bar — liquid glass: translucent + blurred + saturated, with the
       fill thinning slightly once it floats over scrolled content. -->
  <div class="glass glass-strong border-b border-line/80 transition-shadow duration-300" data-header-bar>
    <div class="mx-auto max-w-wide px-4 sm:px-6">
      <div class="header-row flex items-center justify-between gap-4 h-[4.5rem] lg:h-24">
        <a href="/" class="shrink-0" aria-label="Ocean Endodontics — home">
          <Image src={logo} alt="Ocean Endodontics, The Dental Group of Dr. Kelly Kimiko Leong" width={280} densities={[1, 2, 3]} quality={92} loading="eager" class="header-logo h-11 lg:h-[3.75rem] w-auto" />
        </a>

        <!-- Desktop nav -->
        <nav aria-label="Primary" class="nav-desktop hidden xl:block">
          <ul class="flex items-center gap-0.5">
            {
              desktopNav.map((item) =>
                item.children ? (
                  <li class="relative">
                    <details class="nav-dd group">
                      <summary
                        class:list={[
                          'nav-trigger flex items-center gap-1 whitespace-nowrap px-2.5 2xl:px-3.5 py-2 rounded-full text-[0.9rem] font-medium cursor-pointer select-none list-none transition-colors',
                          isActive(item.href) ? 'text-accent-strong' : 'text-ink hover:text-accent-strong',
                        ]}
                      >
                        {item.label}
                        <svg class="w-4 h-4 opacity-55 transition-transform duration-200 group-open:rotate-180" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="m6 9 6 6 6-6" stroke-linecap="round" stroke-linejoin="round"/></svg>
                      </summary>

                      <div
                        class:list={[
                          'nav-panel absolute top-full pt-3',
                          item.align === 'right' ? 'right-0' : 'left-0',
                        ]}
                      >
                        <div
                          class:list={[
                            'mega-card overflow-hidden rounded-2xl glass glass-strong glass-edge',
                            'max-w-[calc(100vw-2rem)]',
                            item.columns && item.columns >= 2 ? 'w-[53rem]' : 'w-[35rem]',
                          ]}
                        >
                          <div class="flex">
                            <!-- Links -->
                            <div class="flex-1 p-3">
                              <div class="flex items-center justify-between px-2.5 pb-1.5">
                                <span class="text-[0.68rem] font-semibold uppercase tracking-[0.16em] text-ink-muted">
                                  {item.megaEyebrow ?? item.label}
                                </span>
                                <a href={item.href} class="group/all inline-flex items-center gap-1 text-xs font-semibold text-accent-strong no-underline hover:text-accent-ink">
                                  View all
                                  <svg class="w-3.5 h-3.5 transition-transform group-hover/all:translate-x-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round"/></svg>
                                </a>
                              </div>
                              <ul class:list={['grid gap-0.5', item.columns && item.columns >= 2 ? 'grid-cols-2' : 'grid-cols-1']}>
                                {item.children.map((c) => (
                                  <li>
                                    <a
                                      href={c.href}
                                      target={c.external ? '_blank' : undefined}
                                      rel={c.external ? 'noopener noreferrer' : undefined}
                                      class="group/link flex items-start gap-3 rounded-xl px-2.5 py-2 no-underline transition-colors hover:bg-surface-subtle"
                                    >
                                      <span class="mt-0.5 inline-flex h-9 w-9 shrink-0 items-center justify-center rounded-lg bg-surface-subtle text-accent-strong ring-1 ring-line transition-colors duration-200 group-hover/link:bg-accent group-hover/link:text-white group-hover/link:ring-accent">
                                        <NavIcon name={c.icon ?? 'tooth'} class="h-5 w-5" />
                                      </span>
                                      <span class="min-w-0">
                                        <span class="block text-[0.9rem] font-semibold text-ink leading-tight group-hover/link:text-accent-strong">
                                          {c.label}
                                          {c.external && <span class="sr-only"> (opens in a new tab)</span>}
                                        </span>
                                        {c.desc && <span class="mt-0.5 block text-xs text-ink-muted leading-snug">{c.desc}</span>}
                                      </span>
                                    </a>
                                  </li>
                                ))}
                              </ul>
                            </div>

                            <!-- Featured card -->
                            {item.featured && (
                              <a
                                href={item.featured.href}
                                target={item.featured.external ? '_blank' : undefined}
                                rel={item.featured.external ? 'noopener noreferrer' : undefined}
                                class:list={[
                                  'group/feat relative w-56 shrink-0 no-underline',
                                  featuredTone[item.featured.tone ?? 'navy'],
                                ]}
                              >
                                <div class="flex h-full flex-col justify-between gap-6 p-5">
                                  <div>
                                    <span class="inline-flex h-10 w-10 items-center justify-center rounded-xl bg-white/15 ring-1 ring-white/25 backdrop-blur-sm">
                                      <NavIcon name={item.featured.icon ?? 'sparkle'} class="h-5 w-5" />
                                    </span>
                                    <p class="mt-4 text-[0.66rem] font-semibold uppercase tracking-[0.16em] text-white/70">{item.featured.eyebrow}</p>
                                    <p class="mt-1 text-lg font-semibold leading-tight">{item.featured.title}</p>
                                    <p class="mt-1.5 text-[0.82rem] leading-snug text-white/85">{item.featured.desc}</p>
                                  </div>
                                  <span class="inline-flex items-center gap-1.5 text-sm font-semibold">
                                    {item.featured.cta}
                                    {item.featured.external && <span class="sr-only"> (opens in a new tab)</span>}
                                    <svg class="w-4 h-4 transition-transform duration-200 group-hover/feat:translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round"/></svg>
                                  </span>
                                </div>
                              </a>
                            )}
                          </div>
                        </div>
                      </div>
                    </details>
                  </li>
                ) : (
                  <li>
                    <a
                      href={item.href}
                      class:list={[
                        'block whitespace-nowrap px-2.5 2xl:px-3.5 py-2 rounded-full text-[0.9rem] font-medium no-underline transition-colors hover:bg-surface-subtle',
                        isActive(item.href) ? 'text-accent-strong' : 'text-ink hover:text-accent-strong',
                      ]}
                    >
                      {item.label}
                    </a>
                  </li>
                )
              )
            }
          </ul>
        </nav>

        <!-- Actions (the phone number lives in the utility bar above, so the
             main bar never has to squeeze it in) -->
        <div class="flex items-center gap-2 sm:gap-3">
          <Button href={site.cta.book.href} size="md" class="hidden sm:inline-flex whitespace-nowrap">Book Appointment</Button>

          <!-- Mobile menu toggle -->
          <button
            type="button"
            class="xl:hidden inline-flex items-center justify-center w-11 h-11 rounded-full ring-1 ring-line text-ink hover:bg-surface-subtle"
            aria-label="Open menu"
            aria-expanded="false"
            aria-controls="mobile-menu"
            data-menu-toggle
          >
            <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true" data-menu-open-icon><path d="M4 7h16M4 12h16M4 17h16" stroke-linecap="round"/></svg>
            <svg class="w-6 h-6 hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true" data-menu-close-icon><path d="M6 6l12 12M18 6 6 18" stroke-linecap="round"/></svg>
          </button>
        </div>
      </div>
    </div>
  </div>

  <!-- Mobile off-canvas menu -->
  <div id="mobile-menu" class="xl:hidden fixed inset-0 z-50 hidden" data-mobile-menu>
    <div class="menu-backdrop absolute inset-0 bg-ink/40 backdrop-blur-sm" data-menu-backdrop></div>
    <div
      class="menu-drawer absolute right-0 top-0 h-full w-[min(92vw,24rem)] rounded-l-3xl glass glass-strong glass-edge flex flex-col"
      role="dialog"
      aria-modal="true"
      aria-label="Site menu"
    >
      <div class="flex items-center justify-between px-5 h-[4.5rem] border-b border-line">
        <Image src={logo} alt="Ocean Endodontics" width={200} densities={[1, 2, 3]} quality={92} class="h-10 w-auto" />
        <button type="button" class="inline-flex items-center justify-center w-11 h-11 rounded-full ring-1 ring-line text-ink" aria-label="Close menu" data-menu-close>
          <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="M6 6l12 12M18 6 6 18" stroke-linecap="round"/></svg>
        </button>
      </div>
      <nav aria-label="Mobile" class="flex-1 overflow-y-auto px-4 py-4">
        <ul class="flex flex-col gap-1">
          {
            primaryNav.map((item) =>
              item.children ? (
                <li>
                  <details class="group rounded-xl">
                    <summary class="flex items-center justify-between px-3 py-3 rounded-xl text-ink font-semibold cursor-pointer list-none select-none hover:bg-surface-subtle">
                      {item.label}
                      <svg class="w-5 h-5 opacity-60 transition-transform group-open:rotate-180" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="m6 9 6 6 6-6" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    </summary>
                    <ul class="pl-2 pb-2 flex flex-col gap-0.5">
                      <li>
                        <a href={item.href} class="flex items-center gap-2.5 px-3 py-2 rounded-lg text-sm font-medium text-accent-strong no-underline hover:bg-surface-subtle">All {item.label}</a>
                      </li>
                      {item.children.map((c) => (
                        <li>
                          <a
                            href={c.href}
                            target={c.external ? '_blank' : undefined}
                            rel={c.external ? 'noopener noreferrer' : undefined}
                            class="flex items-center gap-2.5 px-3 py-2.5 rounded-lg text-sm text-ink-soft no-underline hover:bg-surface-subtle hover:text-accent-strong"
                          >
                            <NavIcon name={c.icon ?? 'tooth'} class="h-4 w-4 shrink-0 text-accent-strong/80" />
                            <span>{c.label}{c.external && <span class="sr-only"> (opens in a new tab)</span>}</span>
                          </a>
                        </li>
                      ))}
                      {item.featured && (
                        <li class="mt-1">
                          <a
                            href={item.featured.href}
                            target={item.featured.external ? '_blank' : undefined}
                            rel={item.featured.external ? 'noopener noreferrer' : undefined}
                            class="flex items-center justify-between gap-2 px-3 py-2 rounded-lg text-sm font-semibold text-accent-strong bg-surface-subtle no-underline hover:bg-surface-muted"
                          >
                            {item.featured.cta}
                            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round"/></svg>
                          </a>
                        </li>
                      )}
                    </ul>
                  </details>
                </li>
              ) : (
                <li>
                  <a href={item.href} class="block px-3 py-3 rounded-xl text-ink font-semibold no-underline hover:bg-surface-subtle">{item.label}</a>
                </li>
              )
            )
          }
        </ul>
      </nav>
      <div class="border-t border-line p-4 flex flex-col gap-2">
        <Button href={site.cta.book.href} size="lg" class="w-full">Book Appointment</Button>
        <Button href={site.phone.href} variant="secondary" size="lg" class="w-full">Call {site.phone.display}</Button>
      </div>
    </div>
  </div>
</header>

<script>
  // Mobile menu open/close + desktop dropdown hover/close + scrolled-header shadow.
  (() => {
    const menu = document.querySelector<HTMLElement>('[data-mobile-menu]');
    const toggle = document.querySelector<HTMLButtonElement>('[data-menu-toggle]');
    const openIcon = document.querySelector<SVGElement>('[data-menu-open-icon]');
    const closeIcon = document.querySelector<SVGElement>('[data-menu-close-icon]');
    const closers = document.querySelectorAll('[data-menu-close], [data-menu-backdrop]');

    let closeTimer: number | undefined;
    const setOpen = (open: boolean) => {
      if (!menu || !toggle) return;
      window.clearTimeout(closeTimer);
      if (open) {
        menu.classList.remove('hidden');
        // next frame so the drawer transition can play
        requestAnimationFrame(() => requestAnimationFrame(() => menu.classList.add('is-open')));
      } else {
        menu.classList.remove('is-open');
        closeTimer = window.setTimeout(() => menu.classList.add('hidden'), 380);
      }
      toggle.setAttribute('aria-expanded', String(open));
      openIcon?.classList.toggle('hidden', open);
      closeIcon?.classList.toggle('hidden', !open);
      document.documentElement.style.overflow = open ? 'hidden' : '';
      if (open) menu.querySelector<HTMLElement>('a, button')?.focus();
    };

    toggle?.addEventListener('click', () => setOpen(menu?.classList.contains('hidden') ?? true));
    closers.forEach((c) => c.addEventListener('click', () => setOpen(false)));
    menu?.querySelectorAll('a').forEach((a) => a.addEventListener('click', () => setOpen(false)));
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        setOpen(false);
        document.querySelectorAll<HTMLDetailsElement>('.nav-dd[open]').forEach((d) => (d.open = false));
      }
    });

    // Desktop dropdowns: open on hover, close others, close on outside click.
    // On open, nudge a wide panel horizontally so it never leaves the viewport.
    const dds = Array.from(document.querySelectorAll<HTMLDetailsElement>('.nav-dd'));
    const positionPanel = (dd: HTMLDetailsElement) => {
      const panel = dd.querySelector<HTMLElement>('.nav-panel');
      const card = panel?.querySelector<HTMLElement>('.mega-card');
      if (!panel || !card) return;
      panel.style.transform = '';
      const rect = card.getBoundingClientRect();
      const pad = 12;
      let shift = 0;
      if (rect.right > window.innerWidth - pad) shift = window.innerWidth - pad - rect.right;
      else if (rect.left < pad) shift = pad - rect.left;
      if (shift) panel.style.transform = `translateX(${Math.round(shift)}px)`;
    };
    dds.forEach((dd) => {
      let t: number | undefined;
      dd.addEventListener('toggle', () => {
        if (dd.open) positionPanel(dd);
        else {
          const p = dd.querySelector<HTMLElement>('.nav-panel');
          if (p) p.style.transform = '';
        }
      });
      dd.addEventListener('mouseenter', () => {
        window.clearTimeout(t);
        dds.forEach((o) => o !== dd && (o.open = false));
        dd.open = true;
      });
      dd.addEventListener('mouseleave', () => {
        t = window.setTimeout(() => (dd.open = false), 160);
      });
    });
    document.addEventListener('click', (e) => {
      dds.forEach((dd) => {
        if (dd.open && !dd.contains(e.target as Node)) dd.open = false;
      });
    });

    // Depth cue: strengthen the sticky bar once the page scrolls.
    const bar = document.querySelector<HTMLElement>('[data-header-bar]');
    if (bar) {
      const onScroll = () => bar.toggleAttribute('data-scrolled', window.scrollY > 6);
      onScroll();
      window.addEventListener('scroll', onScroll, { passive: true });
    }
  })();
</script>

<style>
  /* Hide default <summary> marker */
  summary::-webkit-details-marker { display: none; }
  summary { list-style: none; }
  .nav-dd > summary { position: relative; }

  /* Open-state styling for the trigger (works for hover AND keyboard open) */
  .nav-dd[open] > .nav-trigger { color: var(--color-accent-strong); background: color-mix(in oklab, var(--color-primary-50) 80%, transparent); }
  .nav-trigger:hover { background: color-mix(in oklab, var(--color-primary-50) 80%, transparent); }

  /* Keep desktop dropdown panel above content */
  .nav-panel { z-index: 50; }

  /* Animate the card in on open (the panel itself may carry a translateX clamp,
     so the entry animation lives on the inner card to avoid fighting it). */
  .nav-dd[open] > .nav-panel > .mega-card { animation: navPanelIn 0.2s var(--ease-out-soft) both; }
  @keyframes navPanelIn {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: none; }
  }

  /* Links cascade in behind the card — fast enough to feel instant. */
  .nav-dd[open] .mega-card li { animation: navPanelIn 0.24s var(--ease-out-soft) both; }
  .nav-dd[open] .mega-card li:nth-child(n + 1) { animation-delay: 20ms; }
  .nav-dd[open] .mega-card li:nth-child(n + 3) { animation-delay: 50ms; }
  .nav-dd[open] .mega-card li:nth-child(n + 5) { animation-delay: 80ms; }
  .nav-dd[open] .mega-card li:nth-child(n + 7) { animation-delay: 110ms; }
  .nav-dd[open] .mega-card li:nth-child(n + 9) { animation-delay: 140ms; }

  /* Sticky bar depth on scroll — thin the glass so content shows through. */
  [data-header-bar][data-scrolled] {
    --glass-fill: 85%;
    box-shadow: 0 1px 0 rgba(16, 26, 51, 0.04), 0 10px 30px -18px rgba(16, 26, 51, 0.35);
  }

  /* The mega panel is a DOM descendant of the (filtered) header bar, so its
     own backdrop blur can't reliably sample the page beneath in every engine.
     Run it nearly opaque — glass hint without unblurred ghosting. */
  .mega-card { --glass-fill: 96%; }

  @media (prefers-reduced-motion: reduce) {
    .nav-dd[open] > .nav-panel > .mega-card,
    .nav-dd[open] .mega-card li { animation: none; }
  }
</style>
