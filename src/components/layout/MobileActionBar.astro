---
import { site } from '@data/site';
/**
 * MobileActionBar — the two persistent bottom buttons on phones (Call +
 * Schedule). Coexists with the hovering FloatingActionBar. Hidden on lg+.
 * Occupies real layout space via a spacer so it never covers footer content.
 */
---
<div class="lg:hidden" aria-hidden="false" data-print-hide>
  <div class="fixed inset-x-0 bottom-0 z-40 border-t border-line glass glass-strong pb-[env(safe-area-inset-bottom)]">
    <div class="grid grid-cols-2 gap-2 p-2.5">
      <a
        href={site.phone.href}
        class="inline-flex items-center justify-center gap-2 rounded-full bg-white ring-1 ring-line py-3 font-semibold text-ink no-underline"
      >
        <svg class="w-5 h-5 text-accent-strong" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" aria-hidden="true"><path d="M5 4h3l2 5-2.5 1.5a11 11 0 0 0 5 5L14 12l5 2v3a2 2 0 0 1-2 2A15 15 0 0 1 3 6a2 2 0 0 1 2-2Z" stroke-linejoin="round"/></svg>
        Call
      </a>
      <a
        href={site.cta.book.href}
        class="inline-flex items-center justify-center gap-2 rounded-full bg-accent py-3 font-semibold text-white no-underline"
      >
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" aria-hidden="true"><rect x="3" y="4.5" width="18" height="16" rx="2"/><path d="M8 3v3M16 3v3M3 9h18"/></svg>
        Schedule
      </a>
    </div>
  </div>
  <!-- spacer so fixed bar doesn't cover page bottom -->
  <div class="h-[4.75rem]" aria-hidden="true"></div>
</div>
