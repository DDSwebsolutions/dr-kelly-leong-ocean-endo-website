---
/** Eyebrow — small uppercase label above a heading. */
interface Props { class?: string; tone?: 'accent' | 'muted' | 'light' }
const { class: className = '', tone = 'accent' } = Astro.props;
const tones: Record<string, string> = {
  accent: 'text-accent-strong',
  muted: 'text-ink-muted',
  light: 'text-primary-200',
};
---
<p class:list={['inline-flex items-center gap-2.5 text-sm font-semibold tracking-[0.18em] uppercase', tones[tone], className]}>
  <span class="h-px w-7 bg-gradient-to-r from-current to-transparent opacity-70" aria-hidden="true"></span>
  <slot />
</p>
