---
/** Inline line icons (currentColor, decorative). Keyed by Service.icon. */
interface Props { name: string; class?: string }
const { name, class: className = 'w-6 h-6' } = Astro.props;

const paths: Record<string, string> = {
  tooth:
    'M7.5 3.5C5.5 3.5 4 5 4 7.2c0 1.6.5 2.7.9 4.1.3 1 .5 2.4.7 3.9.2 1.7.4 3.4 1.4 4.4.9.9 1.6.2 1.9-1.2.2-1 .4-2.4.7-3.4.2-.7.6-1 1.1-1s.9.3 1.1 1c.3 1 .5 2.4.7 3.4.3 1.4 1 2.1 1.9 1.2 1-1 1.2-2.7 1.4-4.4.2-1.5.4-2.9.7-3.9.4-1.4.9-2.5.9-4.1C20 5 18.5 3.5 16.5 3.5c-1.6 0-2.6.9-3.4 1.3-.6.3-1.6.3-2.2 0-.8-.4-1.8-1.3-3.4-1.3Z',
  refresh:
    'M4 12a8 8 0 0 1 13.7-5.6L20 8M20 4v4h-4M20 12a8 8 0 0 1-13.7 5.6L4 16M4 20v-4h4',
  microscope: 'M6 20h12M9 20l1-4M8 8l4-2 2 4-4 2-2-4Zm3 3 3 5M14 4l2 1',
  search: 'M11 4a7 7 0 1 0 0 14 7 7 0 0 0 0-14ZM20 20l-4.3-4.3',
  crack: 'M13 3 8 10l4 2-5 9M13 3l4 6-3 1 3 5',
  bolt: 'M13 2 4 14h7l-1 8 9-12h-7l1-8Z',
  shield: 'M12 3 5 6v5c0 4.5 3 8 7 10 4-2 7-5.5 7-10V6l-7-3ZM9.5 12l2 2 3.5-3.5',
  leaf: 'M5 19c0-8 6-14 14-14 0 8-6 14-14 14ZM5 19c3.5-3.5 6.5-5.5 9-7',
  moon: 'M20 14.5A8 8 0 1 1 9.5 4 6.5 6.5 0 0 0 20 14.5Z',
  sparkle: 'M12 3l1.8 5.2L19 10l-5.2 1.8L12 17l-1.8-5.2L5 10l5.2-1.8L12 3ZM18 16l.8 2 2 .8-2 .8-.8 2-.8-2-2-.8 2-.8.8-2Z',
  wave: 'M3 9c2-2 4-2 6 0s4 2 6 0 4-2 6 0M3 15c2-2 4-2 6 0s4 2 6 0 4-2 6 0',
};

const d = paths[name] ?? paths.tooth;
const filled = name === 'tooth';
---
<svg
  class={className}
  viewBox="0 0 24 24"
  fill={filled ? 'currentColor' : 'none'}
  stroke={filled ? 'none' : 'currentColor'}
  stroke-width="1.7"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
  focusable="false"
>
  <path d={d} />
</svg>
