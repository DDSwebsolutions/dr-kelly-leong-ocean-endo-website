---
/**
 * Button — renders as <a> (href) or <button>. Pill shape, soft hover lift.
 * data-btn marks it so the accessibility "highlight links" mode skips it.
 */
interface Props {
  href?: string;
  variant?: 'primary' | 'secondary' | 'navy' | 'ghost' | 'white' | 'urgent';
  size?: 'md' | 'lg';
  external?: boolean;
  type?: 'button' | 'submit';
  class?: string;
  id?: string;
  [key: string]: any;
}

const {
  href,
  variant = 'primary',
  size = 'md',
  external = false,
  type = 'button',
  class: className = '',
  ...rest
} = Astro.props;

const base =
  'group inline-flex items-center justify-center gap-2 font-semibold rounded-full transition-all duration-200 ease-out-soft no-underline text-center leading-tight will-change-transform active:scale-[0.98] motion-reduce:active:scale-100 motion-reduce:hover:translate-y-0';

const sizes: Record<string, string> = {
  md: 'px-5 py-2.5 text-[0.95rem]',
  lg: 'px-7 py-3.5 text-base',
};

// Colored/inset shadows add a glossy, premium edge without altering the base
// fill (so the measured WCAG text-contrast ratios stay intact).
const variants: Record<string, string> = {
  primary:
    'bg-accent text-white shadow-[inset_0_1px_0_rgba(255,255,255,0.22),0_8px_22px_-8px_rgba(0,74,158,0.5)] hover:bg-accent-bg-hover hover:-translate-y-0.5 hover:shadow-[inset_0_1px_0_rgba(255,255,255,0.22),0_16px_34px_-10px_rgba(0,74,158,0.62)]',
  secondary:
    'bg-white text-ink ring-1 ring-line shadow-xs hover:ring-line-strong hover:-translate-y-0.5 hover:shadow-soft',
  navy:
    'bg-ink text-white shadow-[inset_0_1px_0_rgba(255,255,255,0.12),0_8px_22px_-10px_rgba(16,26,51,0.6)] hover:bg-primary-900 hover:-translate-y-0.5 hover:shadow-[inset_0_1px_0_rgba(255,255,255,0.12),0_16px_34px_-12px_rgba(16,26,51,0.7)]',
  ghost: 'text-accent-strong hover:text-accent-ink hover:bg-primary-50/60',
  white:
    'bg-white text-ink ring-1 ring-black/5 shadow-soft hover:-translate-y-0.5 hover:shadow-md',
  urgent:
    'bg-urgent text-white shadow-[inset_0_1px_0_rgba(255,255,255,0.18),0_8px_22px_-8px_rgba(154,51,11,0.5)] hover:brightness-[0.97] hover:-translate-y-0.5',
};

const cls = [base, sizes[size], variants[variant], className].join(' ');
const relAttr = external ? 'noopener noreferrer' : undefined;
const targetAttr = external ? '_blank' : undefined;
---

{
  href ? (
    <a href={href} class={cls} data-btn rel={relAttr} target={targetAttr} {...rest}>
      <slot />
    </a>
  ) : (
    <button type={type} class={cls} data-btn {...rest}>
      <slot />
    </button>
  )
}
