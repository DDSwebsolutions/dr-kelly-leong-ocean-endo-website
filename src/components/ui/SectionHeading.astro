---
import Eyebrow from '@components/ui/Eyebrow.astro';
interface Props {
  eyebrow?: string;
  title: string;
  lead?: string;
  align?: 'left' | 'center';
  tone?: 'dark' | 'light';
  as?: 'h2' | 'h3';
  class?: string;
  maxLead?: string;
}
const {
  eyebrow,
  title,
  lead,
  align = 'left',
  tone = 'dark',
  as = 'h2',
  class: className = '',
  maxLead = 'max-w-2xl',
} = Astro.props;
const Tag = as;
const titleColor = tone === 'light' ? 'text-white' : 'text-ink';
const leadColor = tone === 'light' ? 'text-primary-100' : 'text-ink-soft';
const alignCls = align === 'center' ? 'text-center mx-auto items-center' : 'items-start';
---
<div class:list={['flex flex-col gap-4', alignCls, className]}>
  {eyebrow && <Eyebrow tone={tone === 'light' ? 'light' : 'accent'}>{eyebrow}</Eyebrow>}
  <Tag class:list={[titleColor, 'text-3xl md:text-4xl font-bold']}>{title}</Tag>
  {lead && <p class:list={[leadColor, 'text-lg', maxLead, align === 'center' ? 'mx-auto' : '']}>{lead}</p>}
</div>
