---
import { site } from '@data/site';
import { testimonials } from '@data/reviews';
import SectionHeading from '@components/ui/SectionHeading.astro';
interface Props {
  eyebrow?: string;
  title?: string;
  lead?: string;
  limit?: number;
  tone?: 'default' | 'subtle';
}
const {
  eyebrow = 'In our patients’ words',
  title = 'Kind words about our practice',
  lead,
  limit,
  tone = 'subtle',
} = Astro.props;
const list = limit ? testimonials.slice(0, limit) : testimonials;
---
<section class:list={['py-16 lg:py-20', tone === 'subtle' ? 'bg-surface-subtle' : '']}>
  <div class="mx-auto max-w-content px-6">
    <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-6 mb-10">
      <SectionHeading eyebrow={eyebrow} title={title} lead={lead} />
      <div class="flex items-center gap-3 shrink-0">
        <a href={site.social.google} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 rounded-full bg-white ring-1 ring-line px-4 py-2 text-sm font-semibold text-ink no-underline hover:ring-line-strong">Read on Google</a>
        <a href={site.social.yelp} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 rounded-full bg-white ring-1 ring-line px-4 py-2 text-sm font-semibold text-ink no-underline hover:ring-line-strong">Read on Yelp</a>
      </div>
    </div>

    <ul class="grid gap-5 md:grid-cols-2 lg:grid-cols-3">
      {
        list.map((t) => (
          <li class="flex" data-reveal>
            <figure class="flex flex-col rounded-2xl bg-white ring-1 ring-line p-6 shadow-xs">
              <svg class="w-9 h-9 text-primary-200" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M9.5 7C6.5 7 4 9.5 4 12.5V17h5v-5H6.7c0-1.6 1.3-2.8 2.8-2.8V7Zm9 0c-3 0-5.5 2.5-5.5 5.5V17h5v-5h-2.3c0-1.6 1.3-2.8 2.8-2.8V7Z"/></svg>
              <blockquote class="mt-3 text-ink-soft leading-relaxed flex-1">{t.quote}</blockquote>
              <figcaption class="mt-5 flex items-center gap-3 border-t border-line pt-4">
                <span class="inline-flex w-9 h-9 items-center justify-center rounded-full bg-surface-tint text-accent-strong font-semibold" aria-hidden="true">{t.author.charAt(0)}</span>
                <span>
                  <span class="block text-sm font-semibold text-ink">{t.author}</span>
                  <span class="block text-xs text-ink-muted">{t.treatment} · {t.context}</span>
                </span>
              </figcaption>
            </figure>
          </li>
        ))
      }
    </ul>
    <p class="mt-6 text-xs text-ink-muted max-w-3xl">{site.disclaimers.reviews}</p>
  </div>
</section>
