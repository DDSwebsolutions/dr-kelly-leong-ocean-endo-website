---
import { site } from '@data/site';
/**
 * MapLeaflet — privacy-respecting map using Leaflet + OpenStreetMap tiles.
 * No Google Maps, no third-party trackers. The address and a directions link
 * are provided in text so the map is never the only way to get the info.
 */
interface Props { height?: string }
const { height = '420px' } = Astro.props;
---
<div class="overflow-hidden rounded-3xl ring-1 ring-line shadow-soft bg-surface-muted">
  <div
    id="oe-map"
    style={`height:${height}`}
    role="application"
    aria-label={`Map showing Ocean Endodontics at ${site.address.full}`}
    data-lat={site.geo.lat}
    data-lng={site.geo.lng}
    data-label={site.name}
    data-address={site.address.full}
  ></div>
  <div class="flex flex-wrap items-center justify-between gap-3 bg-white px-5 py-4 border-t border-line">
    <p class="text-sm text-ink-soft">
      <span class="font-semibold text-ink">{site.name}</span> · {site.address.full}
    </p>
    <a href={site.directionsUrl} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1.5 rounded-full bg-accent px-4 py-2 text-sm font-semibold text-white no-underline hover:bg-accent-bg-hover">
      Get directions
      <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M7 17 17 7M8 7h9v9" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </a>
  </div>
</div>

<script>
  import L from 'leaflet';
  import 'leaflet/dist/leaflet.css';

  const el = document.getElementById('oe-map');
  if (el && !el.dataset.init) {
    el.dataset.init = '1';
    const lat = parseFloat(el.dataset.lat || '0');
    const lng = parseFloat(el.dataset.lng || '0');
    const label = el.dataset.label || '';
    const address = el.dataset.address || '';

    const map = L.map(el, { scrollWheelZoom: false, zoomControl: true }).setView([lat, lng], 16);
    L.tileLayer('https://tile.openstreetmap.org/{z}/{x}/{y}.png', {
      maxZoom: 19,
      attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors',
    }).addTo(map);

    const pin = L.divIcon({
      className: 'oe-pin',
      html:
        '<svg width="40" height="52" viewBox="0 0 40 52" xmlns="http://www.w3.org/2000/svg">' +
        '<path d="M20 1C10 1 2 9 2 19c0 12 18 32 18 32s18-20 18-32C38 9 30 1 20 1Z" fill="#0071e3" stroke="#101a33" stroke-width="2"/>' +
        '<circle cx="20" cy="19" r="7" fill="#ffffff"/></svg>',
      iconSize: [40, 52],
      iconAnchor: [20, 50],
      popupAnchor: [0, -46],
    });
    L.marker([lat, lng], { icon: pin, title: label, keyboard: true })
      .addTo(map)
      .bindPopup('<strong>' + label + '</strong><br>' + address);

    // keep map sized correctly after fonts/layout settle
    setTimeout(() => map.invalidateSize(), 200);
  }
</script>

<style is:global>
  .oe-pin { background: transparent; border: none; }
  .leaflet-container { font: inherit; }
</style>
