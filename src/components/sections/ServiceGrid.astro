---
import { services as allServices, type Service } from '@data/services';
import SectionHeading from '@components/ui/SectionHeading.astro';
import ServiceIcon from '@components/ui/ServiceIcon.astro';

interface Props {
  services?: Service[];
  eyebrow?: string;
  title?: string;
  lead?: string;
  limit?: number;
  currentSlug?: string;
  compact?: boolean;
}
const {
  services = allServices,
  eyebrow = 'What we do',
  title = 'Endodontic care that protects your natural teeth',
  lead,
  limit,
  currentSlug,
  compact = false,
} = Astro.props;

let list = services.filter((s) => s.slug !== currentSlug);
if (limit) list = list.slice(0, limit);
---
<section class:list={[compact ? 'py-12' : 'py-16 lg:py-20']}>
  <div class="mx-auto max-w-content px-6">
    {(title || eyebrow) && <SectionHeading eyebrow={eyebrow} title={title} lead={lead} class="mb-10" />}
    <ul class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {
        list.map((s) => (
          <li data-reveal>
            <a
              href={`/services/${s.slug}`}
              class="group flex h-full flex-col rounded-2xl bg-white ring-1 ring-line p-6 no-underline transition-all duration-200 hover:-translate-y-1 hover:shadow-md hover:ring-line-strong"
            >
              <span class="inline-flex w-12 h-12 items-center justify-center rounded-xl bg-surface-tint text-accent-strong ring-1 ring-primary-100">
                <ServiceIcon name={s.icon} class="w-6 h-6" />
              </span>
              <h3 class="mt-4 text-lg font-semibold text-ink group-hover:text-accent-strong transition-colors">{s.title}</h3>
              <p class="mt-2 text-[0.95rem] text-ink-soft leading-relaxed flex-1">{s.shortDescription}</p>
              <span class="mt-4 inline-flex items-center gap-1.5 text-sm font-semibold text-accent-strong">
                Learn more
                <svg class="w-4 h-4 transition-transform group-hover:translate-x-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </span>
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</section>
