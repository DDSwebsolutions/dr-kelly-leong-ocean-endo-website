---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
interface Shot { src: ImageMetadata; alt: string }
interface Props { images: Shot[]; class?: string }
const { images, class: className = '' } = Astro.props;
---
<div class:list={['gap-4 [column-fill:_balance] columns-1 sm:columns-2 lg:columns-3', className]}>
  {
    images.map((shot, i) => (
      <figure class="mb-4 break-inside-avoid overflow-hidden rounded-2xl ring-1 ring-line shadow-xs" data-reveal>
        <Image
          src={shot.src}
          alt={shot.alt}
          widths={[400, 720, 960]}
          sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 24rem"
          quality={80}
          loading={i < 3 ? 'eager' : 'lazy'}
          class="w-full h-auto object-cover"
        />
      </figure>
    ))
  }
</div>
