---
import { site } from '@data/site';
/**
 * JotformEmbed — HIPAA-tier appointment request form.
 * The container carries an accessible name so it doesn't collide with <main>.
 * CSP (public/_headers) whitelists form.jotform.com + cdn.jotfor.ms across
 * frame-src, script-src, connect-src and form-action, or submit silently fails.
 */
interface Props { title?: string; height?: number }
const { title = 'Request an appointment', height = 640 } = Astro.props;
const id = site.booking.jotformId;
const src = site.booking.jotformSrc;
---
<section aria-label="Appointment request form" class="rounded-3xl bg-white ring-1 ring-line shadow-soft overflow-hidden">
  <div class="border-b border-line px-6 py-4 flex items-center justify-between gap-4 flex-wrap">
    <h2 class="text-lg font-semibold text-ink">{title}</h2>
    <p class="text-sm text-ink-muted">Prefer to talk? Call <a href={site.phone.href} class="text-accent-strong font-semibold">{site.phone.display}</a></p>
  </div>
  <div class="relative p-2 sm:p-4">
    <!-- Loading skeleton — fades out once the form iframe has loaded. -->
    <div class="absolute inset-2 sm:inset-4 z-10 flex flex-col items-center justify-center gap-4 rounded-2xl bg-surface-subtle transition-opacity duration-500" data-form-skeleton aria-hidden="true">
      <div class="w-full max-w-md space-y-3 px-8">
        <div class="h-3.5 w-2/5 rounded-full bg-line animate-pulse"></div>
        <div class="h-11 rounded-xl bg-white ring-1 ring-line animate-pulse"></div>
        <div class="h-3.5 w-1/3 rounded-full bg-line animate-pulse [animation-delay:150ms]"></div>
        <div class="h-11 rounded-xl bg-white ring-1 ring-line animate-pulse [animation-delay:150ms]"></div>
        <div class="h-3.5 w-1/2 rounded-full bg-line animate-pulse [animation-delay:300ms]"></div>
        <div class="h-24 rounded-xl bg-white ring-1 ring-line animate-pulse [animation-delay:300ms]"></div>
      </div>
      <p class="text-sm text-ink-muted">Loading the secure request form…</p>
    </div>
    <iframe
      id={`JotFormIFrame-${id}`}
      title="Ocean Endodontics appointment request form"
      allow="geolocation; microphone; camera; fullscreen; payment"
      src={src}
      loading="lazy"
      style={`min-width:100%;max-width:100%;height:${height}px;border:none;`}
      scrolling="no"
      data-form-frame
    ></iframe>
    <noscript>
      <p class="p-6 text-ink-soft">
        The appointment form requires JavaScript. Please call
        <a href={site.phone.href} class="text-accent-strong font-semibold">{site.phone.display}</a>
        or email <a href={site.email.href} class="text-accent-strong font-semibold">{site.email.display}</a> to request an appointment.
      </p>
    </noscript>
  </div>
</section>

<script src="https://cdn.jotfor.ms/s/umd/latest/for-form-embed-handler.js" is:inline></script>
<script define:vars={{ id }}>
  // define:vars (no is:inline) so Astro injects `id` into this inline script.
  if (window.jotformEmbedHandler) {
    window.jotformEmbedHandler("iframe[id='JotFormIFrame-" + id + "']", 'https://form.jotform.com/');
  }

  // Fade the skeleton out once the form has loaded (with a safety timeout so
  // it never lingers if the load event was missed).
  (function () {
    var frame = document.querySelector('[data-form-frame]');
    var skeleton = document.querySelector('[data-form-skeleton]');
    if (!frame || !skeleton) return;
    var hide = function () {
      skeleton.style.opacity = '0';
      window.setTimeout(function () { skeleton.remove(); }, 550);
    };
    frame.addEventListener('load', hide, { once: true });
    window.setTimeout(hide, 8000);
  })();
</script>
