---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import Eyebrow from '@components/ui/Eyebrow.astro';

interface Props {
  eyebrow?: string;
  title: string;
  image: ImageMetadata;
  imageAlt: string;
  reverse?: boolean;
  bullets?: string[];
  tone?: 'default' | 'subtle';
}
const { eyebrow, title, image, imageAlt, reverse = false, bullets, tone = 'default' } = Astro.props;
---
<section class:list={['py-16 lg:py-20', tone === 'subtle' ? 'bg-surface-subtle' : '']}>
  <div class="mx-auto max-w-content px-6">
    <div class="grid gap-10 lg:gap-16 lg:grid-cols-2 items-center">
      <div class:list={['relative', reverse ? 'lg:order-2' : '']} data-reveal>
        <div class="overflow-hidden rounded-3xl shadow-lg ring-1 ring-line">
          <Image src={image} alt={imageAlt} widths={[480, 768, 1024]} sizes="(max-width: 1024px) 100vw, 36rem" class="w-full h-full object-cover aspect-[4/3]" />
        </div>
        <div class="pointer-events-none absolute -z-10 -inset-4 rounded-[2rem] bg-primary-100/40 blur-2xl" aria-hidden="true"></div>
      </div>
      <div class:list={[reverse ? 'lg:order-1' : '', 'flex flex-col gap-5']} data-reveal>
        {eyebrow && <Eyebrow>{eyebrow}</Eyebrow>}
        <h2 class="text-3xl lg:text-4xl font-bold text-ink">{title}</h2>
        <div class="text-lg text-ink-soft leading-relaxed flex flex-col gap-4">
          <slot />
        </div>
        {
          bullets && (
            <ul class="mt-1 flex flex-col gap-3">
              {bullets.map((b) => (
                <li class="flex items-start gap-3">
                  <span class="mt-1 inline-flex w-5 h-5 shrink-0 items-center justify-center rounded-full bg-accent/10 text-accent-strong">
                    <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="m5 12 5 5 9-11" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  </span>
                  <span class="text-ink-soft">{b}</span>
                </li>
              ))}
            </ul>
          )
        }
        <div class="mt-1"><slot name="cta" /></div>
      </div>
    </div>
  </div>
</section>
