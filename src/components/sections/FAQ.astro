---
import SectionHeading from '@components/ui/SectionHeading.astro';
import { renderInline } from '@lib/utils';
interface Faq { q: string; a: string }
interface Props {
  faqs: Faq[];
  eyebrow?: string;
  title?: string;
  lead?: string;
  id?: string;
}
const { faqs, eyebrow = 'Good to know', title = 'Frequently asked questions', lead, id = 'faq' } = Astro.props;
---
<section id={id} class="py-16 lg:py-20 scroll-mt-28">
  <div class="mx-auto max-w-content px-6">
    <SectionHeading eyebrow={eyebrow} title={title} lead={lead} class="mb-10" />
    <div class="grid gap-3 lg:max-w-4xl">
      {
        faqs.map((f) => (
          <details class="group rounded-2xl bg-white ring-1 ring-line hover:ring-line-strong transition-shadow open:shadow-soft" data-reveal>
            <summary class="flex items-center justify-between gap-4 cursor-pointer list-none select-none px-5 py-4 text-ink font-semibold">
              <span>{f.q}</span>
              <span class="shrink-0 inline-flex w-7 h-7 items-center justify-center rounded-full bg-surface-subtle text-accent-strong transition-transform group-open:rotate-45" aria-hidden="true">
                <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M12 5v14M5 12h14" stroke-linecap="round"/></svg>
              </span>
            </summary>
            <div class="faq-body px-5 pb-5 -mt-1 text-ink-soft leading-relaxed" set:html={renderInline(f.a)} />
          </details>
        ))
      }
    </div>
  </div>
</section>
<style>
  summary::-webkit-details-marker { display: none; }
</style>
