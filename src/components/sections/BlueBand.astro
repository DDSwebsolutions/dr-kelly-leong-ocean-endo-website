---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import Eyebrow from '@components/ui/Eyebrow.astro';
/**
 * BlueBand — the full-bleed "block of blue" between white sections.
 * With an image (e.g. a San Francisco photo) it becomes a tall, editorial,
 * duotone-blue band with content anchored bottom-left, Apple-style. Without an
 * image it falls back to a rich brand gradient built from the design tokens.
 */
interface Props {
  image?: ImageMetadata;
  imageAlt?: string;
  eyebrow?: string;
  title: string;
  lead?: string;
  align?: 'center' | 'left';
}
const { image, imageAlt = '', eyebrow, title, lead, align } = Astro.props;
// Image bands read best bottom-left; gradient bands read best centered.
const a = align ?? (image ? 'left' : 'center');
const alignCls = a === 'center' ? 'mx-auto text-center items-center' : 'items-start';
---
{
  image ? (
    <section class="relative isolate flex min-h-[64svh] items-end overflow-hidden bg-ink">
      <Image src={image} alt={imageAlt} widths={[768, 1080]} sizes="100vw" quality={82} loading="lazy" class="absolute inset-0 -z-10 h-full w-full object-cover" />
      <div class="absolute inset-0 -z-10 bg-primary-900/35 mix-blend-multiply" aria-hidden="true" />
      <div class="absolute inset-0 -z-10 bg-gradient-to-t from-ink/90 via-ink/35 to-ink/10" aria-hidden="true" />
      <div class="absolute inset-0 -z-10 bg-gradient-to-r from-ink/55 to-transparent" aria-hidden="true" />
      <div class="mx-auto w-full max-w-content px-6 pb-16 pt-28 lg:pb-20">
        <div class:list={['flex max-w-2xl flex-col gap-5', alignCls]} data-reveal>
          {eyebrow && <Eyebrow tone="light">{eyebrow}</Eyebrow>}
          <h2 class="text-4xl font-semibold tracking-tight text-white sm:text-5xl lg:text-6xl [text-wrap:balance] [text-shadow:0_2px_30px_rgba(16,26,51,0.5)]">{title}</h2>
          {lead && <p class="max-w-xl text-lg text-white/90 sm:text-xl [text-shadow:0_1px_16px_rgba(16,26,51,0.55)]">{lead}</p>}
          <div class:list={[a === 'center' ? 'justify-center' : '', 'mt-3 flex flex-wrap gap-3']}>
            <slot />
          </div>
        </div>
      </div>
    </section>
  ) : (
    <section class="relative isolate overflow-hidden bg-primary-900">
      <div class="absolute inset-0 -z-10 bg-gradient-to-br from-primary-800 via-primary-900 to-ink" aria-hidden="true" />
      <div class="pointer-events-none absolute -left-24 -top-24 -z-10 h-[32rem] w-[32rem] rounded-full bg-primary-500/25 blur-3xl" aria-hidden="true" />
      <div class="pointer-events-none absolute -bottom-32 -right-16 -z-10 h-[36rem] w-[36rem] rounded-full bg-accent/20 blur-3xl" aria-hidden="true" />
      <div class="mx-auto max-w-content px-6 py-24 lg:py-32">
        <div class:list={['flex max-w-3xl flex-col gap-5', alignCls]} data-reveal>
          {eyebrow && <Eyebrow tone="light">{eyebrow}</Eyebrow>}
          <h2 class="text-3xl font-semibold tracking-tight text-white sm:text-4xl lg:text-5xl [text-wrap:balance]">{title}</h2>
          {lead && <p class="text-lg text-primary-100 sm:text-xl">{lead}</p>}
          <div class:list={[a === 'center' ? 'justify-center' : '', 'mt-3 flex flex-wrap gap-3']}>
            <slot />
          </div>
        </div>
      </div>
    </section>
  )
}
