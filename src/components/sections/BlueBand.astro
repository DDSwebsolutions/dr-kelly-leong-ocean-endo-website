---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import Eyebrow from '@components/ui/Eyebrow.astro';
/**
 * BlueBand — a full-bleed "block of blue" between white sections. By default it
 * uses a rich brand gradient (navy + ocean blue) built from the design tokens,
 * not stock photography. Pass a real photo (e.g. office) only if you want one.
 */
interface Props {
  image?: ImageMetadata;
  imageAlt?: string;
  eyebrow?: string;
  title: string;
  lead?: string;
  align?: 'center' | 'left';
}
const { image, imageAlt = '', eyebrow, title, lead, align = 'center' } = Astro.props;
const alignCls = align === 'center' ? 'mx-auto text-center items-center' : 'items-start';
---
<section class="relative isolate overflow-hidden bg-primary-900">
  {
    image ? (
      <>
        <Image src={image} alt={imageAlt} widths={[768, 1280, 1920]} sizes="100vw" loading="lazy" class="absolute inset-0 -z-10 h-full w-full object-cover" />
        <div class="absolute inset-0 -z-10 bg-gradient-to-b from-primary-900/70 via-ink/70 to-ink/85" aria-hidden="true"></div>
      </>
    ) : (
      <>
        <div class="absolute inset-0 -z-10 bg-gradient-to-br from-primary-800 via-primary-900 to-ink" aria-hidden="true"></div>
        <div class="pointer-events-none absolute -left-24 -top-24 -z-10 h-[32rem] w-[32rem] rounded-full bg-primary-500/25 blur-3xl" aria-hidden="true"></div>
        <div class="pointer-events-none absolute -bottom-32 -right-16 -z-10 h-[36rem] w-[36rem] rounded-full bg-accent/20 blur-3xl" aria-hidden="true"></div>
      </>
    )
  }

  <div class="mx-auto max-w-content px-6 py-24 lg:py-32">
    <div class:list={['flex max-w-3xl flex-col gap-5', alignCls]} data-reveal>
      {eyebrow && <Eyebrow tone="light">{eyebrow}</Eyebrow>}
      <h2 class="text-3xl font-semibold tracking-tight text-white sm:text-4xl lg:text-5xl [text-wrap:balance]">{title}</h2>
      {lead && <p class="text-lg text-primary-100 sm:text-xl">{lead}</p>}
      <div class:list={[align === 'center' ? 'justify-center' : '', 'mt-3 flex flex-wrap gap-3']}>
        <slot />
      </div>
    </div>
  </div>
</section>
