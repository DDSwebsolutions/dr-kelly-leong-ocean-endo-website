---
import { getCollection } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import PageHero from '@components/sections/PageHero.astro';
import CtaBand from '@components/sections/CtaBand.astro';
import { webPageSchema } from '@lib/schemas';

const crumbs = [
  { name: 'Home', path: '/' },
  { name: 'Education Center', path: '/education' },
];
const posts = (await getCollection('education', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime()
);
const description =
  'The Ocean Endodontics Education Center: clear, trustworthy guides on root canals, tooth pain, dental emergencies, and saving your natural teeth, from Dr. Kelly Kimiko Leong.';
const schema = [webPageSchema({ path: '/education', title: 'Education Center', description, crumbs })];
const fmt = (d: Date) => d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---
<BaseLayout title="Education Center" seoTitle="Endodontics Education Center | Ocean Endodontics" description={description} schema={schema}>
  <PageHero
    eyebrow="Education center"
    title="Clear answers about endodontic care"
    lead="Plain-language guides to help you understand tooth pain, root canals, and what to do in an emergency, written by our team."
    crumbs={crumbs}
  />

  <section class="py-16 lg:py-20">
    <div class="mx-auto max-w-content px-6">
      <ul class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {
          posts.map((post) => (
            <li data-reveal>
              <a href={`/education/${post.id}`} class="group flex h-full flex-col rounded-2xl bg-white ring-1 ring-line p-6 no-underline transition-all hover:-translate-y-1 hover:shadow-md hover:ring-line-strong">
                <span class="self-start rounded-full bg-surface-tint text-accent-strong px-3 py-1 text-xs font-semibold">{post.data.category}</span>
                <h2 class="mt-4 text-lg font-semibold text-ink group-hover:text-accent-strong leading-snug">{post.data.title}</h2>
                <p class="mt-2 text-[0.95rem] text-ink-soft flex-1">{post.data.description}</p>
                <p class="mt-4 text-xs text-ink-muted">{fmt(post.data.publishDate)}{post.data.readingTime ? ` · ${post.data.readingTime}` : ''}</p>
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <CtaBand />
</BaseLayout>
