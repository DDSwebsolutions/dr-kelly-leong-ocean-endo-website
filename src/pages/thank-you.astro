---
import BaseLayout from '@layouts/BaseLayout.astro';
import Button from '@components/ui/Button.astro';
import { site } from '@data/site';

const description = 'Thank you for contacting Ocean Endodontics. We have received your request and will be in touch soon.';

const next = [
  { title: 'We review your request', body: 'A member of our team reads every request personally, usually within one business day.' },
  { title: 'We call to confirm', body: 'We’ll reach out to confirm your appointment time and answer any questions about your visit or insurance.' },
  { title: 'You come in', body: 'Park free in the lot through the breezeway, check in, and we’ll take great care of you from there.' },
];
---
<BaseLayout title="Thank You" description={description} noindex={true}>
  <section class="py-16 lg:py-24">
    <div class="mx-auto max-w-2xl px-6 text-center">
      <span class="hero-rise inline-flex w-16 h-16 items-center justify-center rounded-full bg-gradient-to-br from-accent to-[#005cba] text-white shadow-[0_10px_30px_-10px_rgba(0,74,158,0.5)]" style="--hero-delay: 60ms" aria-hidden="true">
        <svg class="w-8 h-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" aria-hidden="true"><path d="m5 12 5 5 9-11" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </span>
      <h1 class="hero-rise mt-6 text-4xl font-bold text-ink" style="--hero-delay: 180ms">Thank you, we’ve got it</h1>
      <p class="hero-rise mt-4 text-lg text-ink-soft" style="--hero-delay: 300ms">
        Your request has been received. Here’s what happens next.
      </p>

      <ol class="hero-rise mt-8 grid gap-4 text-left sm:grid-cols-3" style="--hero-delay: 420ms">
        {
          next.map((s, i) => (
            <li class="rounded-2xl bg-white ring-1 ring-line p-5">
              <span class="inline-flex w-8 h-8 items-center justify-center rounded-full bg-accent/10 text-accent-strong text-sm font-bold" aria-hidden="true">{i + 1}</span>
              <h2 class="mt-3 text-base font-semibold text-ink">{s.title}</h2>
              <p class="mt-1.5 text-sm text-ink-soft leading-relaxed">{s.body}</p>
            </li>
          ))
        }
      </ol>

      <div class="mt-6 rounded-2xl bg-urgent-soft ring-1 ring-urgent/20 p-6 text-left">
        <p class="font-semibold text-ink">Need to be seen sooner, or in pain now?</p>
        <p class="mt-2 text-ink-soft text-[0.95rem]">Please call us directly at <a href={site.phone.href} class="font-semibold text-accent-strong">{site.phone.display}</a> and we’ll do our best to see you the same day. {site.disclaimers.emergency}</p>
      </div>
      <div class="mt-8 flex flex-wrap justify-center gap-3">
        <Button href="/">Back to home</Button>
        <Button href="/education" variant="secondary">Read our patient guides</Button>
      </div>
    </div>
  </section>
</BaseLayout>
