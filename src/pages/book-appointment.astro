---
import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumbs from '@components/ui/Breadcrumbs.astro';
import Button from '@components/ui/Button.astro';
import JotformEmbed from '@components/sections/JotformEmbed.astro';
import { site } from '@data/site';
import { webPageSchema } from '@lib/schemas';

const crumbs = [
  { name: 'Home', path: '/' },
  { name: 'Book Appointment', path: '/book-appointment' },
];
const description =
  'Request an appointment with Ocean Endodontics in San Francisco. Complete our secure online request form, or call (415) 741-3636. Same-day visits reserved for emergencies.';
// noindex is optional here; booking pages are PHI-zone (no tracking) but useful to index for "book" intent.
const schema = [webPageSchema({ path: '/book-appointment', title: 'Book an Appointment', description, crumbs })];
---
<BaseLayout title="Book an Appointment" seoTitle="Book an Appointment | Ocean Endodontics, San Francisco" description={description} schema={schema}>
  <section class="bg-surface-subtle border-b border-line">
    <div class="mx-auto max-w-wide px-6 py-12 lg:py-14">
      <div class="max-w-2xl flex flex-col gap-4" data-reveal>
        <Breadcrumbs crumbs={crumbs} />
        <h1 class="text-4xl lg:text-5xl font-bold text-ink">Request an appointment</h1>
        <p class="text-lg text-ink-soft">
          Tell us a little about what’s going on and how to reach you, and our team will confirm the soonest time that works. No dentist referral is required. In significant pain? Call <a href={site.phone.href} class="font-semibold text-accent-strong">{site.phone.display}</a> and we’ll prioritize your visit.
        </p>
      </div>
    </div>
  </section>

  <section class="py-12 lg:py-16">
    <div class="mx-auto max-w-wide px-6">
      <div class="grid gap-8 lg:grid-cols-[1fr_20rem] items-start">
        <div data-reveal>
          <JotformEmbed title="Appointment request" />
        </div>

        <aside class="flex flex-col gap-5">
          <div class="rounded-2xl bg-white ring-1 ring-line p-6">
            <h2 class="text-lg font-semibold text-ink">Prefer to call?</h2>
            <p class="mt-2 text-sm text-ink-soft">Our team is glad to help you schedule and answer questions.</p>
            <div class="mt-4 flex flex-col gap-2">
              <Button href={site.phone.href} class="w-full">Call {site.phone.display}</Button>
              <Button href={site.email.href} variant="secondary" class="w-full">Email us</Button>
            </div>
          </div>

          <div class="rounded-2xl bg-white ring-1 ring-line p-6">
            <h2 class="text-lg font-semibold text-ink">Already a patient?</h2>
            <p class="mt-2 text-sm text-ink-soft">Access your forms and records securely through our patient portal.</p>
            <a href={site.portals.patient} target="_blank" rel="noopener noreferrer" class="mt-3 inline-flex items-center gap-1.5 text-sm font-semibold text-accent-strong no-underline">Open patient portal →</a>
          </div>

          <div class="rounded-2xl bg-surface-subtle ring-1 ring-line p-6">
            <h2 class="text-sm font-semibold uppercase tracking-wide text-ink-muted">Office hours</h2>
            <ul class="mt-3 text-sm space-y-1">
              {site.hours.map((h) => (
                <li class="flex justify-between"><span class="text-ink-soft">{h.short}</span><span class={h.closed ? 'text-ink-muted' : 'font-medium text-ink'}>{h.closed ? 'Closed' : '8:30 AM – 5 PM'}</span></li>
              ))}
            </ul>
          </div>

          <div class="rounded-2xl bg-urgent-soft ring-1 ring-urgent/20 p-6">
            <h2 class="text-base font-semibold text-ink">Life-threatening emergency?</h2>
            <p class="mt-2 text-sm text-ink-soft">{site.disclaimers.emergency}</p>
          </div>
        </aside>
      </div>
    </div>
  </section>
</BaseLayout>
