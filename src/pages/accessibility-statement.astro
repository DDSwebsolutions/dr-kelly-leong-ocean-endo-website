---
import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumbs from '@components/ui/Breadcrumbs.astro';
import { site } from '@data/site';
import { webPageSchema } from '@lib/schemas';

const crumbs = [
  { name: 'Home', path: '/' },
  { name: 'Accessibility Statement', path: '/accessibility-statement' },
];
const updated = 'July 5, 2026';
const description = 'Ocean Endodontics is committed to making our website welcoming and usable for as many people as possible. Contact us if you encounter any barrier and we will help.';
const schema = [webPageSchema({ path: '/accessibility-statement', title: 'Accessibility Statement', description, crumbs })];
---
<BaseLayout title="Accessibility Statement" description={description} schema={schema}>
  <section class="bg-surface-subtle border-b border-line">
    <div class="mx-auto max-w-3xl px-6 py-12">
      <Breadcrumbs crumbs={crumbs} class="mb-4" />
      <h1 class="text-4xl font-bold text-ink">Accessibility Statement</h1>
      <p class="mt-3 text-ink-muted">Last updated {updated}</p>
    </div>
  </section>

  <div class="mx-auto max-w-3xl px-6 py-12">
    <article class="prose-content">
      <p>{site.name} wants this website to be welcoming and usable for as many people as possible, including people with disabilities. We consider accessibility part of good patient care, and we work to follow recognized best practices as we build and maintain the site. This is an ongoing effort, and we continue to make improvements over time.</p>

      <p>The site also offers optional on-screen tools, opened from the button in the lower corner of each page, that let you adjust settings such as text size, contrast, and motion to suit how you prefer to read.</p>

      <h2>Tell us how we can help</h2>
      <p>If any part of this website is difficult to use, or you would like information from it in a different format, please contact us and we will be glad to help. We also welcome requests for accommodations for your visit. Your feedback helps us find and address issues, and we work to resolve them as quickly as we reasonably can.</p>
      <ul>
        <li>Phone: <a href={site.phone.href}>{site.phone.display}</a></li>
        <li>Email: <a href={site.email.href}>{site.email.display}</a></li>
        <li>Address: {site.address.full}</li>
      </ul>
    </article>
  </div>
</BaseLayout>
