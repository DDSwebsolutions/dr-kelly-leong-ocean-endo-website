---
import BaseLayout from '@layouts/BaseLayout.astro';
import PageHero from '@components/sections/PageHero.astro';
import MapLeaflet from '@components/sections/MapLeaflet.astro';
import OfficePeek from '@components/sections/OfficePeek.astro';
import FAQ from '@components/sections/FAQ.astro';
import Button from '@components/ui/Button.astro';
import { site } from '@data/site';
import { generalFaqs } from '@data/reviews';
import { webPageSchema } from '@lib/schemas';
import victorians from '@assets/images/sf/victorians.jpg';

const crumbs = [
  { name: 'Home', path: '/' },
  { name: 'Contact', path: '/contact' },
];
const description =
  'Contact Ocean Endodontics in San Francisco. Call (415) 741-3636, email info@oceanendosf.com, or visit 2645 Ocean Ave, Ste 203. Free parking and easy transit.';
const schema = [webPageSchema({ path: '/contact', title: 'Contact Us', description, crumbs })];

const contactRows = [
  { label: 'Phone', value: site.phone.display, sub: 'Fastest way to reach us, especially in pain', href: site.phone.href, icon: 'phone' },
  { label: 'Email', value: site.email.display, sub: 'We reply within one business day', href: site.email.href, icon: 'mail' },
  { label: 'Fax', value: site.fax.display, sub: 'For records and referrals', href: site.fax.href, icon: 'printer' },
];
---
<BaseLayout title="Contact Us" seoTitle="Contact Ocean Endodontics | San Francisco Endodontist" description={description} schema={schema}>
  <PageHero
    eyebrow="Contact"
    title="We’re here to help"
    lead="Scheduling a root canal, have a question about treatment, or need urgent care? Reach out by phone, email, or our online request form. We look forward to caring for you."
    crumbs={crumbs}
    image={victorians}
    imageAlt="Classic San Francisco Victorian houses"
  >
    <div class="flex flex-wrap gap-3">
      <Button href={site.cta.book.href}>Request an appointment</Button>
      <Button href={site.phone.href} variant="secondary">Call {site.phone.display}</Button>
    </div>
  </PageHero>

  <section class="py-14 lg:py-20">
    <div class="mx-auto max-w-content px-6">
      <div class="grid gap-8 lg:grid-cols-2 lg:items-start">
        <div class="flex flex-col gap-5">
          <!-- Contact methods: full-width rows so long values (like the email
               address) always have room and never clip. -->
          <div class="overflow-hidden rounded-3xl bg-white ring-1 ring-line shadow-soft" data-reveal>
            <h2 class="border-b border-line px-6 py-4 text-sm font-semibold uppercase tracking-[0.14em] text-ink-muted">Get in touch</h2>
            <ul class="divide-y divide-line">
              {
                contactRows.map((c) => (
                  <li>
                    <a href={c.href} class="group flex items-center gap-4 px-6 py-5 no-underline transition-colors hover:bg-surface-subtle">
                      <span class="inline-flex h-12 w-12 shrink-0 items-center justify-center rounded-2xl bg-surface-tint text-accent-strong ring-1 ring-primary-100 transition-all duration-300 group-hover:bg-accent group-hover:text-white group-hover:ring-accent">
                        {c.icon === 'phone' && <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" aria-hidden="true"><path d="M5 4h3l2 5-2.5 1.5a11 11 0 0 0 5 5L14 12l5 2v3a2 2 0 0 1-2 2A15 15 0 0 1 3 6a2 2 0 0 1 2-2Z" stroke-linejoin="round"/></svg>}
                        {c.icon === 'mail' && <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" aria-hidden="true"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="m4 7 8 6 8-6"/></svg>}
                        {c.icon === 'printer' && <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" aria-hidden="true"><path d="M6 9V3h12v6M6 18H4v-6h16v6h-2M8 14h8v7H8z"/></svg>}
                      </span>
                      <span class="min-w-0">
                        <span class="block text-xs font-semibold uppercase tracking-wide text-ink-muted">{c.label}</span>
                        <span class="block break-all font-semibold text-ink text-base sm:text-lg leading-snug group-hover:text-accent-strong">{c.value}</span>
                        <span class="mt-0.5 block text-sm text-ink-muted">{c.sub}</span>
                      </span>
                      <svg class="ml-auto w-5 h-5 shrink-0 text-ink-muted transition-transform group-hover:translate-x-0.5 group-hover:text-accent-strong" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M9 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    </a>
                  </li>
                ))
              }
            </ul>
          </div>

          <div class="rounded-3xl bg-white ring-1 ring-line shadow-soft p-6" data-reveal>
            <h2 class="text-lg font-semibold text-ink">Our address</h2>
            <p class="mt-2 text-ink-soft">{site.address.streetLine1}, {site.address.streetLine2}<br />{site.address.city}, {site.address.state} {site.address.zip}</p>
            <p class="mt-2 text-sm text-ink-muted">{site.parkingNote}</p>
            <div class="mt-4">
              <Button href={site.directionsUrl} external variant="secondary">Get directions</Button>
            </div>
          </div>

          <div class="rounded-3xl bg-white ring-1 ring-line shadow-soft p-6" data-reveal>
            <h2 class="text-lg font-semibold text-ink">Hours of operation</h2>
            <ul class="mt-3 text-[0.95rem] divide-y divide-line">
              {site.hours.map((h) => (
                <li class="flex justify-between py-2">
                  <span class="text-ink-soft">{h.day}</span>
                  <span class={h.closed ? 'text-ink-muted' : 'font-medium text-ink'}>{h.closed ? 'Closed' : '8:30 AM – 5:00 PM'}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>

        <div class="flex flex-col gap-5 lg:sticky lg:top-28">
          <div data-reveal><MapLeaflet height="480px" /></div>
          <div class="rounded-3xl bg-urgent-soft ring-1 ring-urgent/20 p-6" data-reveal>
            <h2 class="text-lg font-semibold text-ink">In a dental emergency?</h2>
            <p class="mt-2 text-ink-soft text-[0.95rem]">Call us as early as you can and we’ll do our best to see you the same day. {site.disclaimers.emergency}</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <OfficePeek keys={['reception-logo', 'operatory-1', 'gallery-40']} title="Visit a calm, welcoming office" />

  <FAQ faqs={generalFaqs} />
</BaseLayout>
