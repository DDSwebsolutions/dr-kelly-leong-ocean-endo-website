---
import BaseLayout from '@layouts/BaseLayout.astro';
import PageHero from '@components/sections/PageHero.astro';
import CtaBand from '@components/sections/CtaBand.astro';
import FAQ from '@components/sections/FAQ.astro';
import Button from '@components/ui/Button.astro';
import { site } from '@data/site';
import { generalFaqs } from '@data/reviews';
import { webPageSchema } from '@lib/schemas';

const crumbs = [
  { name: 'Home', path: '/' },
  { name: 'New Patients', path: '/new-patient' },
];
const description =
  'What to expect as a new patient at Ocean Endodontics in San Francisco: your first visit, what to bring, forms, insurance, parking, and how we keep you comfortable.';
const steps = [
  { title: 'Before your visit', body: 'We’ll send any needed forms through our secure patient portal so you can complete them ahead of time. Have your dentist’s name and any recent X-rays handy if you have them.' },
  { title: 'What to bring', body: 'A photo ID, your dental insurance information, a list of current medications, and any referral or images from your general dentist. If you have questions, jot them down so we can cover everything.' },
  { title: 'When you arrive', body: 'Park for free in the lot through the breezeway or on the street, check in with our friendly front desk, and settle into our calm reception area. Waits are usually short.' },
  { title: 'Your consultation', body: 'Dr. Leong reviews your history, performs focused testing, and takes imaging as needed. She’ll explain what she finds on screen and walk you through your options in plain language.' },
  { title: 'Treatment & comfort', body: 'Many problems can be treated the same day. We take time to fully numb the area, and nitrous oxide or oral conscious sedation are available if you’d like extra help relaxing.' },
  { title: 'After your visit', body: 'You’ll leave with clear written aftercare and a direct way to reach us. In most cases you’ll return to your general dentist for the final restoration, and we’ll send them complete notes and images.' },
];
const schema = [webPageSchema({ path: '/new-patient', title: 'New Patient Guide', description, crumbs })];
---
<BaseLayout title="New Patient Guide" seoTitle="New Patients | Ocean Endodontics, San Francisco" description={description} schema={schema}>
  <PageHero
    eyebrow="New patients"
    title="Your first visit, made simple"
    lead="We want your first visit to feel calm and clear. Here’s exactly what to expect, so there are no surprises. No dentist referral is required to see us."
    crumbs={crumbs}
  >
    <div class="flex flex-wrap gap-3">
      <Button href={site.cta.book.href}>Book your first visit</Button>
      <Button href={site.portals.patient} external variant="secondary">Patient portal</Button>
    </div>
  </PageHero>

  <section class="py-16 lg:py-20">
    <div class="mx-auto max-w-content px-6">
      <ol class="grid gap-5 md:grid-cols-2">
        {
          steps.map((s, i) => (
            <li class="flex gap-4 rounded-2xl bg-white ring-1 ring-line p-6" data-reveal>
              <span class="shrink-0 inline-flex w-10 h-10 items-center justify-center rounded-full bg-accent text-white font-semibold" aria-hidden="true">{i + 1}</span>
              <div>
                <h2 class="text-lg font-semibold text-ink">{s.title}</h2>
                <p class="mt-1.5 text-ink-soft text-[0.95rem] leading-relaxed">{s.body}</p>
              </div>
            </li>
          ))
        }
      </ol>

      <div class="mt-8 grid gap-5 sm:grid-cols-2">
        <div class="rounded-2xl bg-surface-subtle ring-1 ring-line p-6">
          <h2 class="text-lg font-semibold text-ink">Insurance & fees</h2>
          <p class="mt-2 text-ink-soft text-[0.95rem]">We verify your benefits in advance and review any costs before treatment begins. Learn more about insurance and payment options.</p>
          <a href="/financial" class="mt-3 inline-flex items-center gap-1.5 text-sm font-semibold text-accent-strong no-underline">Insurance & financing →</a>
        </div>
        <div class="rounded-2xl bg-urgent-soft ring-1 ring-urgent/20 p-6">
          <h2 class="text-lg font-semibold text-ink">In pain right now?</h2>
          <p class="mt-2 text-ink-soft text-[0.95rem]">Don’t wait. Call us early and we’ll do our best to see you the same day. {site.disclaimers.emergency}</p>
          <a href={site.phone.href} class="mt-3 inline-flex items-center gap-1.5 text-sm font-semibold text-accent-strong no-underline">Call {site.phone.display} →</a>
        </div>
      </div>
    </div>
  </section>

  <FAQ faqs={generalFaqs} />
  <CtaBand />
</BaseLayout>
