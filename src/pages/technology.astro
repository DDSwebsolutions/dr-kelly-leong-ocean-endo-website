---
import BaseLayout from '@layouts/BaseLayout.astro';
import PageHero from '@components/sections/PageHero.astro';
import FeatureRow from '@components/sections/FeatureRow.astro';
import SectionHeading from '@components/ui/SectionHeading.astro';
import CtaBand from '@components/sections/CtaBand.astro';
import FAQ from '@components/sections/FAQ.astro';
import Button from '@components/ui/Button.astro';
import { site } from '@data/site';
import { generalFaqs } from '@data/reviews';
import { webPageSchema } from '@lib/schemas';
import microscope from '@assets/images/photos/microscope.jpg';
import operatory from '@assets/images/photos/operatory-1.jpg';

const crumbs = [
  { name: 'Home', path: '/' },
  { name: 'About', path: '/about' },
  { name: 'Technology', path: '/technology' },
];
const description =
  'The technology behind precise endodontic care in San Francisco: operating microscope on every case, cone beam 3D imaging, low-radiation digital X-rays, and modern irrigation and obturation.';
const tech = [
  { title: 'Operating microscope', body: 'Used for every procedure to reveal the fine internal anatomy of a tooth, so treatment is precise and thorough.' },
  { title: 'Cone beam 3D imaging (CBCT)', body: 'Creates a detailed three-dimensional view when needed, revealing extra canals, cracks, and infection that flat X-rays can miss.' },
  { title: 'Low-radiation digital X-rays', body: 'Instant, high-resolution images with a fraction of the radiation of older film, shared with you on screen.' },
  { title: 'Modern irrigation & obturation', body: 'Advanced disinfection and sealing systems help clean the canal system thoroughly and seal it for a lasting result.' },
];
const schema = [webPageSchema({ path: '/technology', title: 'Technology', description, crumbs })];
---
<BaseLayout title="Our Technology" seoTitle="Endodontic Technology in San Francisco | Ocean Endodontics" description={description} schema={schema}>
  <PageHero
    eyebrow="Technology"
    title="Technology that supports comfort and results"
    lead="Precise diagnosis and efficient, comfortable treatment start with the right tools. Here is what we use on every case."
    crumbs={crumbs}
    image={microscope}
    imageAlt="A clinician using a Zeiss operating microscope at Ocean Endodontics"
  />

  <section class="py-16 lg:py-20">
    <div class="mx-auto max-w-content px-6">
      <SectionHeading eyebrow="Our tools" title="Built for precision" class="mb-10" />
      <ul class="grid gap-5 sm:grid-cols-2">
        {
          tech.map((t) => (
            <li class="rounded-2xl bg-white ring-1 ring-line p-7" data-reveal>
              <h3 class="text-xl font-semibold text-ink">{t.title}</h3>
              <p class="mt-2 text-ink-soft leading-relaxed">{t.body}</p>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <FeatureRow
    eyebrow="See it in real time"
    title="You see what we see"
    image={operatory}
    imageAlt="A modern operatory with chairside monitor at Ocean Endodontics"
    tone="subtle"
    bullets={[
      'X-rays and 3D images shared on a chairside monitor',
      'Clear explanations of the findings and the plan',
      'Detailed documentation sent to your referring dentist',
    ]}
  >
    <p>
      Technology is only useful when it helps you understand your care. Monitors in every operatory let us show you your images and walk through exactly what is happening and why, so you feel informed and in control from start to finish.
    </p>
    <Button slot="cta" href="/our-office" variant="secondary">Tour our office</Button>
  </FeatureRow>

  <FAQ faqs={generalFaqs} />
  <CtaBand />
</BaseLayout>
