---
import { Image } from 'astro:assets';
import BaseLayout from '@layouts/BaseLayout.astro';
import PageHero from '@components/sections/PageHero.astro';
import CtaBand from '@components/sections/CtaBand.astro';
import Button from '@components/ui/Button.astro';
import { site } from '@data/site';
import { ceCourses } from '@data/ceCourses';
import { webPageSchema } from '@lib/schemas';

const crumbs = [
  { name: 'Home', path: '/' },
  { name: 'For Doctors', path: '/for-doctors' },
  { name: 'CE Courses', path: '/ce-courses' },
];
const description =
  'Continuing education for referring dentists from Ocean Endodontics in San Francisco, a PACE-approved program provider. Courses on Botox in dentistry, resorption, endodontic procedural accidents, and more.';
const schema = [webPageSchema({ path: '/ce-courses', title: 'CE Courses', description, crumbs })];
---
<BaseLayout title="CE Courses for Dentists" seoTitle="Dental CE Courses in San Francisco | Ocean Endodontics" description={description} schema={schema}>
  <PageHero
    eyebrow="For referring doctors"
    title="Continuing education courses"
    lead="Ocean Endodontics is a PACE-approved program provider. We host continuing education and case-collaboration sessions for dentists across San Francisco. Contact us for the current schedule and to RSVP."
    crumbs={crumbs}
  >
    <div class="flex flex-wrap gap-3">
      <Button href={site.phone.href}>Call to RSVP</Button>
      <Button href={site.email.href} variant="secondary">Email us</Button>
    </div>
  </PageHero>

  <section class="py-16 lg:py-20">
    <div class="mx-auto max-w-content px-6">
      <ul class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
        {
          ceCourses.map((c) => (
            <li data-reveal>
              <a href={`/ce-courses/${c.slug}`} class="group flex h-full flex-col overflow-hidden rounded-3xl bg-white ring-1 ring-line no-underline transition-all hover:-translate-y-1 hover:shadow-md hover:ring-line-strong">
                <div class="overflow-hidden bg-surface-subtle">
                  <Image src={c.flyer} alt={`${c.title} continuing education flyer`} widths={[360, 560, 760]} sizes="(max-width: 640px) 100vw, 24rem" quality={86} class="w-full h-auto object-contain" />
                </div>
                <div class="flex flex-1 flex-col p-6">
                  <h2 class="text-lg font-semibold text-ink group-hover:text-accent-strong">{c.title}</h2>
                  <p class="mt-2 text-sm text-ink-soft flex-1">{c.topic}</p>
                  <span class="mt-4 inline-flex items-center gap-1.5 text-sm font-semibold text-accent-strong">
                    View course
                    <svg class="w-4 h-4 transition-transform group-hover:translate-x-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  </span>
                </div>
              </a>
            </li>
          ))
        }
      </ul>
      <p class="mt-8 text-sm text-ink-muted max-w-3xl">
        Ocean Endodontics is a locally approved PACE Program Provider for FAGD/MAGD credit. Approval does not imply acceptance by any regulatory authority or AGD endorsement. Course dates vary; contact our office for the current schedule. Courses and case-collaboration sessions are part of our <a href="/partnership-philosophy" class="text-accent-strong">partnership philosophy</a> with referring dentists.
      </p>
    </div>
  </section>

  <CtaBand
    title="Bring CE to your team"
    text="Interested in a course or a case-collaboration session? Call or email and we’ll share upcoming dates."
    showCall={true}
  />
</BaseLayout>
